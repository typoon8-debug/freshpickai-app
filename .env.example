# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase CLI (마이그레이션 자동화, CI에서 사용)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_DB_PASSWORD=your_db_password

# ─── AI 서비스 ────────────────────────────────────────────────────────────────
# Anthropic Claude (chat, recommend, agent)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (임베딩: text-embedding-3-small)
OPENAI_API_KEY=sk-proj-...

# ─── AI RAG 파라미터 ──────────────────────────────────────────────────────────
# 벡터 유사도 임계값 (기본 0.78 — 높을수록 정확, 낮을수록 넓은 범위)
RAG_VECTOR_THRESHOLD=0.78
# 시맨틱 캐시 히트 임계값 (기본 0.92)
RAG_CACHE_THRESHOLD=0.92

# ─── 결제 ─────────────────────────────────────────────────────────────────────
# 토스페이먼츠 (테스트: test_ck_... / 라이브: live_ck_...)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ─── 지도·배송 ────────────────────────────────────────────────────────────────
# Kakao Developers > REST API 키
KAKAO_REST_KEY=your_kakao_rest_key
GEOCODE_RATE_LIMIT_PER_MIN=120
GEOCODE_DRY_RUN=false
# STRICT: 배달권역 밖 주소는 주문 차단 / WARN: 경고만 표시
NEXT_PUBLIC_DELIVERY_GUARD_MODE=STRICT
NEXT_PUBLIC_DEFAULT_DELIVERY_RADIUS_M=1000

# ─── 모니터링 ────────────────────────────────────────────────────────────────
# Sentry (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=freshpickai-app
SENTRY_AUTH_TOKEN=sntrys_...

# PostHog (https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── 앱 메타 ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=0.1.0
